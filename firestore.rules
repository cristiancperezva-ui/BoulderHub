rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAdmin() {
      return request.auth != null && 
        'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    function isRouteSetter() {
      return request.auth != null && 
        'routesetter' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    function isClimber() {
      return request.auth != null && 
        'climber' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    // Config (admins list)
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // Solo admin puede cambiar roles de otros
      allow write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }

    // Walls
    match /walls/{wallId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Color categories
    match /colorCategories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blocks
    match /blocks/{blockId} {
      allow read: if true;
      allow create: if isAdmin() || isRouteSetter();
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.routeSetterId || isAdmin());
      allow delete: if false;

      // Subcolección: attempts
      match /attempts/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Challenges
    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.creatorId;
      allow delete: if false;

      // Subcolección: results
      match /results/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcolección: ratings
      match /ratings/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId &&
          request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      }
    }
  }
}
